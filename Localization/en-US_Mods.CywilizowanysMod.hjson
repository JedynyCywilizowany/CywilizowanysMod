		}
	}

	CywilsConfig_Debug: {
		DisplayName: Debug Config

		ReportPackets: {
			Label: Report Packets
			Tooltip: ""
		}
	}
}

Keybinds.ToggleAutosellForItem.DisplayName: Toggle Autosell For Item

Tooltips: {
	ItemAutosold: {
		Inventory: This item is autosold
		List: This item is listed as autosold, click to remove it
	}

	AutosellingEnabled: {
		True: Autoselling is currently enabled, right click to disable
		False: Autoselling is currently disabled, right click to enable
	}
}

