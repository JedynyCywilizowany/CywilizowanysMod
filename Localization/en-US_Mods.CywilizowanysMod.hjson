	Autoselling: {
		DisplayName: Autoselling
		Description: Selected items will be autosold if possible
	}
}

Configs: {
	CywilsConfig_Client: {
		DisplayName: Client Config

		TextureLoadOptimization: {
			Label: Texture Load Optimization
			Tooltip:
				'''
				If enabled, most textures will only be loaded once they are used
				Might be incompatibile with some mods
				'''
		}

		AutosellWhenBagIsFull: {
			Label: Autosell When Bag Is Full
			Tooltip: Whether Autoselling Bag should continue collecting items when it's full, even though no more coins will be gained
		}
	}

