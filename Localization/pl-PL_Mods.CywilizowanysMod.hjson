	ItemAutosold: {
		Inventory: Ten przedmiot jest automatycznie sprzedawany
		List: Ten przedmiot jest na liście do autosprzedaży, kliknij aby go usunąć
	}

	AutosellingEnabled: {
		True: Autosprzedaż włączona, kliknij prawym aby wyłączyć
		False: Autosprzedaż wyłączona, kliknij prawym aby włączyć
	}
}

UI: {
