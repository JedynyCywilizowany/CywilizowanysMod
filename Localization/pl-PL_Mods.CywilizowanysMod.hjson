	}

	DevSet_Cywil_Boots: {
		DisplayName: Buty Jedynego Cywilizowanego
		// Tooltip: ""
	}

	DevSet_Cywil_Wings: {
		DisplayName: Płaszcz Jedynego Cywilizowanego
		// Tooltip: ""
	}

	Autoseller: {
		DisplayName: Stacja do autosprzedaży
		Tooltip: Automatycznie sprzedaje wybrane przedmioty do najszczęśliwszego kupca w zasięgu, ale po zredukowanej cenie
	}

	AutosellerBag: {
		DisplayName: Torba do autosprzedaży
		Tooltip:
			'''
			Pozwala na zdalną autosprzedaż, ale ma ograniczoną pojemność
			Opróżnia się gdy normalna autosprzedaż jest możliwa
			'''
	}
}

Buffs: {
	Autoselling: {
		DisplayName: Autosprzedaż
		Description: Wybrane przedmioty będą automatycznie sprzedawane, jeśli to możliwe
	}
}

Configs: {
	CywilsConfig_Client: {
		DisplayName: Ustawienia klienta

		TextureLoadOptimization: {
			Label: Optymalizacja ładowania tekstur
			Tooltip:
				'''
				Jeśli włączone, większość tekstur będzie ładowane tylko gdy są używane
				Może być niekompatybilne z niektórymi modami
				'''
		}

		AutosellWhenBagIsFull: {
			Label: Autosprzedaż przy pełnej torbie
			Tooltip: Czy torba do autosprzedaży powinna wciąż zbierać przedmioty jak jest pełna, mimo że nie zapewni więcej monet
		}
	}

	CywilsConfig_World: {
		DisplayName: Ustawienia świata

		ShowDayCounter: {
			Label: Licznik dni
			Tooltip:
				'''
				Komunikuje w chatcie ile dni minęło na tym świecie, przy wchodzeniu i każdego ranka
				Jeśli ta opcja jest wyłączona, dni wciąż są liczone, ale nie wyświetlane
				'''
		}

		UnstuckItems: {
			Label: Wydostawanie przedmiotów
			Tooltip: Przedmioty, które utknęły w ziemii, będą powoli przemieszczać się w kierunku najbliższej pustej przestreni
		}
	}

	CywilsConfig_Debug: {
		// DisplayName: Debug Config

		ReportPackets: {
			// Label: Report Packets
			// Tooltip: Broadcast in chat whenever a CywilsPacket is sent or received
		}
	}
}

Keybinds.ToggleAutosellForItem.DisplayName: Przełącz autosprzedaż dla przedmiotu

